# =========================
# 🚫 Node Modules
# =========================
node_modules/
server/node_modules/

# =========================
# 🔐 Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# 🧾 Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# 🧠 Runtime / Temp Files
# =========================
tmp/
temp/
.cache/
*.tmp

# =========================
# 💻 OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# 🧪 Editor / IDE Files
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# 📦 Build / Output
# =========================
dist/
build/

# =========================
# 🔥 Server Secrets / Config
# =========================
server/config/*.env
server/config/*.json

# =========================
# 🧪 Experimental / Backup Files
# =========================
*~
*.bak
*.backup
*.old

# Ignore accidental duplicate files like this 👇
server/app.js1

# =========================
# 📸 Optional: Ignore Large Assets (if needed)
# =========================
# public/assets/images/uploads/
# public/assets/videos/

# =========================
# 🧾 Database Dumps (IMPORTANT)
# =========================
*.sql
*.dump
*.db
*.sqlite

# But keep schema if you want version control
!database/schema.sql

# =========================
# 🔑 API Keys / Secrets
# =========================
*.pem
*.key
*.crt
