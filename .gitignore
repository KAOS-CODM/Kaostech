# =========================
# 🚫 Node Modules
# =========================
node_modules/
**/node_modules/
server/node_modules/

# =========================
# 🔐 Environment Variables
# =========================
.env
.env.local
.env.*.local
!.env.example

# =========================
# 🧾 Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# =========================
# 🧠 Runtime / Temp Files
# =========================
tmp/
temp/
.cache/
*.tmp

# =========================
# 💻 OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# 🧪 Editor / IDE Files
# =========================
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

# =========================
# 📦 Build / Output
# =========================
dist/
build/

# =========================
# 🔥 Server Secrets / Config
# =========================
server/config/*.env
server/config/*.json

# =========================
# 🧪 Experimental / Backup Files
# =========================
*~
*.bak
*.backup
*.old
*.orig
*.rej

# Ignore accidental duplicate files like this 👇
Untitled-1.css
blogg.js
server/app.js1

# =========================
# 🧾 Database Dumps (IMPORTANT)
# =========================
*.sql
*.dump
*.db
*.sqlite

# But keep schema if you want version control
!database/schema.sql

# =========================
# 🔑 API Keys / Secrets
# =========================
*.pem
*.key
*.crt
